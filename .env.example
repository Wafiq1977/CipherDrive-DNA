# ============================================================
# CipherDrive-DNA MVP — Environment Variable Template
# ============================================================
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#
#   cp .env.example .env
#   nano .env
# ============================================================

# ── MySQL ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=cipherdrive_dna
MYSQL_USER=cipherdrive
MYSQL_PASSWORD=change-me-strong-password

# ── JWT ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Then base64-encode the result again so Spring can decode it:
#   echo -n "$(openssl rand -base64 32)" | base64
JWT_SECRET_KEY=change-me-base64-encoded-256bit-secret
JWT_ISSUER=cipherdrive-dna

# ── MinIO ──────────────────────────────────────────────────────
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-secret-key
MINIO_BUCKET=cipherdrive-files
